generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int     @id @default(autoincrement())
  name     String
  email    String  @unique
  password String
  role     String  @default("user")
  records  Record[]
}

model Record {
  id        Int      @id @default(autoincrement())
  amount    Float
  type      String   // income / expense
  category  String
  date      DateTime
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
}